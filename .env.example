# Sanity (required for /studio and any Sanity fetches)
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Optional: pinned API version (see sanity/env.ts)
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity Presentation / Draft Mode
# Generate a "viewer" token: https://www.sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=
# Optional: editor token to run `npm run seed:sanity` (creates siteSettings + events page)
# SANITY_API_WRITE_TOKEN=
# Optional browser token for real-time live updates in the Presentation iframe
# NEXT_PUBLIC_SANITY_TOKEN=
# Override the preview origin for remote/production deployments
# SANITY_STUDIO_PREVIEW_ORIGIN=https://www.standingsunwines.com

# Site URL for metadata, OG, sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.standingsunwines.com

# Mailchimp (newsletter API — server must match API key suffix, e.g. us4)
MAILCHIMP_SERVER=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Mapbox (if you embed maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

NEXT_TELEMETRY_DISABLED=1

# Resend (contact / inquiry emails)
RESEND_API_KEY=
# Verified sender, e.g. Standing Sun Wines <hello@yourdomain.com>
RESEND_FROM=
HOST_INQUIRY_TO_EMAIL=
